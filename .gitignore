# Rust
/target/
**/*.rs.bk

# Engine database files (test/demo artifacts)
*.db

# Bun / Node (future bindings)
node_modules/
.bun/
# Assembled per-platform npm packages (generated by scripts/build-npm-packages.ts)
clients/bun/dist/

# macOS
.DS_Store

# Editors
.idea/
.vscode/
*.swp

# Tooling artifacts
.playwright-mcp/

# Release binaries downloaded from a GitHub release for a manual npm publish
# (native libengine .so/.dylib/.dll + engine.h). Generated/fetched, never source.
/artifacts/
/artifacts-gh/

# Local env / secrets
.env
.env.*
!.env.example

# Local manual end-to-end test kit (not for CI; developer-run)
/local-e2e/

# Claude Code session memory (agent-local, not project source)
/.claude/projects/
