{
  "name": "@twilldb/bun",
  "version": "0.3.2",
  "description": "Embed the Twill DB engine in-process via bun:ffi.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/bihaviour/twill-db"
  },
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "optionalDependencies": {
    "@twilldb/engine-linux-x64": "0.3.2",
    "@twilldb/engine-linux-arm64": "0.3.2",
    "@twilldb/engine-darwin-x64": "0.3.2",
    "@twilldb/engine-darwin-arm64": "0.3.2",
    "@twilldb/engine-win32-x64": "0.3.2"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "example": "bun run examples/notes.ts",
    "example:vectors": "bun run examples/vector-memory.ts",
    "example:compose": "bun run examples/compose.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
