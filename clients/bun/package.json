{
  "name": "@twilldb/bun",
  "version": "0.1.0",
  "description": "Embed the Twill DB engine in-process via bun:ffi (Phase 1, file:// backend).",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/bihaviour/twill-db"
  },
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./better-auth": "./src/better-auth.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "example": "bun run examples/notes.ts",
    "example:vectors": "bun run examples/vector-memory.ts",
    "example:compose": "bun run examples/compose.ts",
    "example:auth": "bun run examples/auth-app.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "better-auth": "^1.6.20"
  }
}
