// {{name}} — a Twill DB starter for Node (embedded path).
//
// The engine runs in-process via @twilldb/node (koffi FFI); there is no server
// to start and no infrastructure to provision. The storage backend is chosen
// entirely by the connection-string scheme below. The same code runs unchanged
// on Bun (swap the import for "@twilldb/bun") and on Node-based frameworks
// (Next.js, Astro, Nuxt, Remix, SvelteKit) — open one Database per process.
//
//   npm install
//   npm start            # node app.ts  (Node >= 22.18 runs .ts directly)
//
// The native libengine ships with @twilldb/node as a per-platform optional
// dependency, so no `cargo build` is needed. Override with TWILLDB_ENGINE_PATH.

import { open } from "@twilldb/node";

// file://    embedded, persists to a local file
// s3://|r2://|gs://  storage-disaggregated (credentials come from the env)
const url = "{{db_url}}";
console.log(`opening ${url}`);

const db = open(url);
try {
  db.exec(`CREATE TABLE IF NOT EXISTS notes (
    id     INTEGER PRIMARY KEY,
    body   TEXT NOT NULL,
    weight REAL
  )`);

  // Start fresh each run for a deterministic demo.
  db.exec("DELETE FROM notes");

  // Parameterized inserts (values bind positionally; no string interpolation).
  const insert = db.prepare("INSERT INTO notes (id, body, weight) VALUES (?, ?, ?)");
  try {
    insert.run(1, "buy milk", 1.0);
    insert.run(2, "write spec", 2.5);
    insert.run(3, "ship it", 9.9);
  } finally {
    insert.finalize();
  }

  // A transaction: commit on normal return; the commit blocks until durable.
  db.transaction((tx) => {
    tx.exec("UPDATE notes SET weight = weight + 1 WHERE id = 1");
    tx.exec("INSERT INTO notes (id, body, weight) VALUES (4, 'tidy up', 0.5)");
  });

  console.log("\nall notes (by weight desc):");
  for (const row of db.query<{ id: string; body: string; weight: string }>(
    "SELECT id, body, weight FROM notes ORDER BY weight DESC",
  )) {
    console.log(`  #${row.id}  ${row.body.padEnd(16)} ${row.weight}`);
  }

  console.log(`\nlast commit LSN: ${db.lastLsn}`);
  console.log(`persisted to ${url} — re-run to see it reload from the WAL.`);
} finally {
  db.close();
}
